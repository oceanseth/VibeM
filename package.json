{
  "name": "vibem",
  "private": true,
  "version": "0.1.0",
  "description": "Vibe coding with a focus on VMs — define KPIs, spawn agent VMs that drive Tasklet/Mulerun/etc., eval on cron.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:web dev:orchestrator",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:orchestrator": "npm --workspace apps/orchestrator run dev",
    "build": "npm run build --workspaces --if-present",
    "build:agent": "docker build -t vibem/agent-runtime:latest packages/agent-runtime",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
