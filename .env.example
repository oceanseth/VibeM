# Copy to .env and fill in. .env is gitignored.

# OpenAI — used by the outside (orchestrator) agent and inside-VM agents.
OPENAI_API_KEY=sk-...

# Optional: if you want the outside admin agent to use Claude instead of GPT-4o
# ANTHROPIC_API_KEY=sk-ant-...

# Orchestrator
PORT=8787
DATA_DIR=./data
DOCKER_SOCKET=/var/run/docker.sock

# Inside-VM agent image — built from packages/agent-runtime
AGENT_IMAGE=vibem/agent-runtime:latest

# Hard caps to keep costs bounded during a hackathon
MAX_VMS=8
MAX_TOKENS_PER_VM=200000
MAX_STEPS_PER_VM=80
